# ── Node.js Backend ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Anthropic API key (required for Claude Vision analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Python Detector ───────────────────────────────────────────────────────────
# URL of the Python FastAPI detector service
PYTHON_DETECTOR_URL=http://localhost:8000

# Timeout in ms for calls to the Python detector (default 120s)
PYTHON_DETECTOR_TIMEOUT_MS=120000

# Port the Python API will listen on
DETECTOR_PORT=8000

# ── Optional overrides ────────────────────────────────────────────────────────
# Path to Noiseprint directory (defaults to detector/Noiseprint)
# NOISEPRINT_PATH=D:\path\to\Noiseprint

# Path to Tesseract executable (defaults to standard Windows install path)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
